
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Author {
  id            String  @id @default(uuid())
  name          String  
  nationality   String?
  birthYear     Int?
  books         Book[]
}

model Book {
  id            String @id @default(uuid())
  title         String
  year          Int
  genre         String
  available     Boolean @default(true)
  authorId      String
  author        Author  @relation(fields: [authorId], references: [id])
}